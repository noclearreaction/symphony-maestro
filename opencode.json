{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/deepseek/deepseek-chat-v3-0324",
  "instructions": [
    "AGENTS.md",
    "governance/constitution.md",
  ],
  "provider": {
    "openrouter": {
      "options": {
        "baseURL": "http://localhost:8080/v1"
      }
    }
  },
  "default_agent": "orchestrator",
  "agent": {
    "build": {
      "description": "Disabled during bootstrap to prevent premature implementation.",
      "disable": true
    },
    "general": {
      "description": "Disabled to enforce role-bounded conversations.",
      "disable": true
    }
  }
}