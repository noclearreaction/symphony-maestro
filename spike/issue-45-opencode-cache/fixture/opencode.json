{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter-proxy/google/gemini-2.5-flash",
  "provider": {
    "openrouter-proxy": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter Proxy",
      "options": {
        "baseURL": "http://openrouter-proxy:8080/v1"
      },
      "models": {
        "google/gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash"
        }
      }
    }
  },
  "instructions": [
    "INSTRUCTIONS.md"
  ],
  "agent": {
    "build": {
      "prompt": "{file:./prompt.md}",
      "permission": {
        "bash": "deny",
        "read": "deny",
        "edit": "deny",
        "write": "deny",
        "glob": "deny",
        "grep": "deny",
        "task": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "todowrite": "deny",
        "skill": "deny"
      }
    }
  }
}
