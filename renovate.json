{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": false,
  "ignoreUnstable": true,
  "minimumReleaseAge": "1 day",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update version pins in .devcontainer/versions.env",
      "managerFilePatterns": ["/(^|/)versions\\.env$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?) depName=(?<depName>.+?)\\n\\S+=(?<currentValue>[^\\s]+)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["dockerfile"],
      "enabled": false
    },
    {
      "matchFileNames": [".devcontainer/versions.env"],
      "groupName": "devcontainer tools",
      "automerge": false
    },
    {
      "matchDepNames": ["ubuntu"],
      "ignoreUnstable": true,
      "allowedVersions": "/^\\d+\\.04$/"
    },
    {
      "matchDepNames": ["debian"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)-slim$"
    }
  ]
}
