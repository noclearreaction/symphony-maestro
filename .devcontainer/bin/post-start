#!/bin/sh
# .devcontainer/bin/post-start — runs on every container start via postStartCommand
# This script is executed (not sourced), so it runs in its own process.
set -e

# Initialize SSH directory from read-only host mount.
# The host .ssh is mounted to .ssh-host to avoid virtiofs socket binding limitations.
# We copy keys and config to a local .ssh directory where SSH agent can create sockets.
if [ -d "$HOME/.ssh-host" ] && [ ! -d "$HOME/.ssh" ]; then
	mkdir -p "$HOME/.ssh"
	cp -r "$HOME/.ssh-host"/* "$HOME/.ssh/" 2>/dev/null || true
	chmod 700 "$HOME/.ssh"
	chmod 600 "$HOME/.ssh"/* 2>/dev/null || true
fi

# Keep post-start fast: run only local tool checks.
task devcontainer:doctor

# Rubato lifecycle is managed via task namespace.
task rubato:autostart

# Optional: run dependency update checks when explicitly requested.
# This can be slow due to network/API calls.
if [ "${POSTSTART_CHECK_VERSIONS:-0}" = "1" ]; then
	task devcontainer:versions
fi

# ---------------------------------------------------------------------------
# Future hooks (add here when needed):
# ---------------------------------------------------------------------------

# Git hooks setup (when tools/hooks/ is added to this repo):
# task hooks:install

# ---------------------------------------------------------------------------
# MCP sidecar stubs (add docker run invocations here when sidecars are needed):
# ---------------------------------------------------------------------------

# Example:
# docker run -d --rm --name mcp-git \
#   -v /var/run/docker.sock:/var/run/docker.sock \
#   ghcr.io/org/mcp-git:latest
