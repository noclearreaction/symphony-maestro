#!/bin/sh
# .devcontainer/bin/post-start — runs on every container start via postStartCommand
# This script is executed (not sourced), so it runs in its own process.
set -e

# Keep post-start fast: run only local tool checks.
task devcontainer:doctor

# Rubato lifecycle is managed via task namespace.
task rubato:autostart

# Optional: run dependency update checks when explicitly requested.
# This can be slow due to network/API calls.
if [ "${POSTSTART_CHECK_VERSIONS:-0}" = "1" ]; then
	task devcontainer:versions
fi

# ---------------------------------------------------------------------------
# Future hooks (add here when needed):
# ---------------------------------------------------------------------------

# Git hooks setup (when tools/hooks/ is added to this repo):
# task hooks:install

