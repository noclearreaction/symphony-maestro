{
  "name": "${localWorkspaceFolderBasename}",
  "initializeCommand": ".devcontainer/bin/initialize",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer-runtime",
  "runServices": ["devcontainer-runtime"],
  "workspaceFolder": "/workspace",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:1": {
      "configureZshAsDefaultShell": true
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/sshd:1": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false,
      "installDockerBuildx": true
    }
  },
  "mounts": [
    "source=${localEnv:HOME}/.config/gh,target=/home/vscode/.config/gh,type=bind,readonly",
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh-host,type=bind,readonly",
    "source=${localWorkspaceFolderBasename}-vscode-extensions,target=/home/vscode/.vscode-server/extensions,type=volume",
    "source=${localWorkspaceFolderBasename}-vscode-user-data,target=/home/vscode/.vscode-server/data/User,type=volume"
  ],
  "postCreateCommand": "sh -c 'LOG=/tmp/devcontainer-postCreate.log && echo \"[$(date -u +%Y-%m-%dT%H:%M:%SZ)] postCreateCommand starting\" > \"$LOG\" && { [ -d \"$HOME/.ssh-host\" ] && echo \"✓ .ssh-host mount found\" || echo \"✗ .ssh-host mount NOT found\"; } | tee -a \"$LOG\" && for dir in /home/vscode/.vscode-server/extensions /home/vscode/.vscode-server/data/User; do [ -d \"$dir\" ] && sudo chown -R vscode:vscode \"$dir\"; done || true && echo \"[$(date -u +%Y-%m-%dT%H:%M:%SZ)] postCreateCommand complete\" >> \"$LOG\"'",
  "postStartCommand": ".devcontainer/bin/post-start",
  "remoteUser": "vscode",
  "remoteEnv": {
    "LOCAL_WORKSPACE_FOLDER": "${localWorkspaceFolder}",
    "OPENAI_BASE_URL": "http://127.0.0.1:8080/v1",
    "OPENAI_API_KEY": "rubato-local"
  },
  "shutdownAction": "stopCompose",
  "customizations": {
    "vscode": {
      "extensions": []
    }
  }
}
